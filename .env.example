# ============================================================
# 镖局风云 CLI - LLM 配置
# ============================================================
# 复制本文件为 .env 并填入你的 key
#
# 获取 OpenRouter API Key: https://openrouter.ai/keys
# ============================================================

# [必填] 你的 OpenRouter API Key
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# [可选] 覆盖默认模型 (默认: deepseek/deepseek-chat-v3-0324)
# 推荐中文模型:
#   deepseek/deepseek-chat-v3-0324   — 便宜，中文极强，创意好
#   qwen/qwen-2.5-72b-instruct      — 阿里通义，中文稳定
#   google/gemini-2.5-flash          — 快且便宜，多语言好
#   anthropic/claude-sonnet-4        — 贵但质量顶级
# LLM_MODEL=deepseek/deepseek-chat-v3-0324

# [可选] 强制使用本地 Ollama (无需 key)
# LLM_BACKEND=ollama
