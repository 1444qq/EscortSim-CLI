{
  "name": "escort-sim",
  "version": "0.2.0",
  "description": "镖局风云 - AI驱动的镖局经营文字游戏",
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "dev": "electron .",
    "cli": "node main.js",
    "start": "electron .",
    "build": "electron-builder --win",
    "build:dir": "electron-builder --win --dir"
  },
  "build": {
    "appId": "com.escortsim.cli",
    "productName": "镖局风云",
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron/**/*",
      "src/**/*",
      "assets/**/*"
    ],
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerLanguages": [
        "zh_CN"
      ],
      "shortcutName": "镖局风云"
    }
  },
  "devDependencies": {
    "electron": "^35.0.0",
    "electron-builder": "^26.8.1"
  }
}
